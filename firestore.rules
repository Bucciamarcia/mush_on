rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    function userAccount() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.account
        : null;
    }

    function isAccountMember(account) {
      return isSignedIn() && userAccount() == account;
    }

    function isMusher(account) {
      return isAccountMember(account) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userLevel == "musher";
    }

    function isSelf(uid) {
      return isSignedIn() && uid == request.auth.uid;
    }

    function isUnassignedSelfProfile(uid) {
      return isSelf(uid) &&
             request.resource.data.uid == uid &&
             request.resource.data.email == request.auth.token.email &&
             (!("account" in request.resource.data) ||
              request.resource.data.account == null) &&
             (!("userLevel" in request.resource.data) ||
              request.resource.data.userLevel == "handler");
    }

    function onlyUpdatesProfileFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(["name", "lastLogin"]);
    }

    // Users can read their own user doc and update safe profile fields.
    // Account assignment and roles are server-controlled.
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isUnassignedSelfProfile(uid);
      allow update: if isSelf(uid) && onlyUpdatesProfileFields();
      allow delete: if false;
    }

    match /users/{uid}/{document=**} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    // Public-facing content: anyone can read; only members of the account can write
    match /customerFacing/{account}/{document=**} {
      allow read: if true;  // public (no auth required)
      allow write: if isSignedIn() && userAccount() == account;
    }
    
    // Public booking catalogue and schedule data.
    match /accounts/{account}/data/bookingManager/tours/{tourId} {
  		allow read: if true;      // public
  		allow write: if false;     // nobody can write
		}
    match /accounts/{account}/data/bookingManager/customerGroups/{customerGroupId} {
  		allow read: if true;      // public
  		allow write: if false;     // nobody can write
		}
    match /accounts/{account}/data/bookingManager/customers/{customerId} {
      allow read, write: if isAccountMember(account);
		}
    match /accounts/{account}/data/bookingManager/bookings/{bookingId} {
      allow read, write: if isAccountMember(account);
		}
    match /accounts/{account}/data/bookingManager/partners/{partnerId} {
      // Public read: the customer-facing booking page resolves &partner=<code>.
      allow read: if true;
      // Only admins (musher) may add / edit / archive partners. Partners are
      // never deleted — archived instead.
      allow write: if isMusher(account);
		}
    match /accounts/{account}/data/bookingManager/tours/{tourId}/prices/{pricing} {
  		allow read: if true;      // public
  		allow write: if false;     // nobody can write
		}
    match /accounts/{account}/data/bookingManager {
  		allow read: if true;      // public
  		allow write: if false;     // nobody can write
		}
    match /global/privacyPolicy {
  		allow read: if true;      // public
  		allow write: if false;     // nobody can write
		}


    // Restrict account data to the user's assigned account.
    match /accounts/{account} {
      allow read, write: if isAccountMember(account);
    }

    match /accounts/{account}/integrations/{integration}/{document=**} {
      allow read, write: if isAccountMember(account) && integration != "stripe";
    }

    match /accounts/{account}/integrations/stripe {
      allow read: if isAccountMember(account);
      allow write: if false;
    }

    match /accounts/{account}/integrations/stripe/accounts/{stripeAccount} {
      allow read: if isAccountMember(account);
      allow write: if false;
    }

    match /accounts/{account}/{collection}/{document=**} {
      allow read, write: if isAccountMember(account) &&
        collection != "integrations";
    }
    
    // Checkout sessions contain payment metadata and are server-only.
    match /checkoutSessions/{session} {
    allow read, write: if false;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
